NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root@localhost:3306/dbforge"
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# SMTP (optional — without these, email logs to API console in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=DBForge <noreply@yourcompany.com>

# OpenAI (optional — AI schema generator falls back to built-in patterns)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
