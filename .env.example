NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root:root@localhost:3306/dbforge"
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Registration (defaults: allowed in dev, blocked in production)
# ALLOW_PUBLIC_REGISTRATION=true

# Encrypt saved database connection profiles (required in production)
# DB_PROFILE_ENCRYPTION_KEY=generate-a-long-random-secret

# SMTP (optional — without these, email logs to API console in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=DBForge <noreply@yourcompany.com>

# Weekly team digest cron (UTC Monday 08:00 by default; requires SMTP)
# WEEKLY_DIGEST_CRON=true
# WEEKLY_DIGEST_CRON_UTC_DAY=1
# WEEKLY_DIGEST_CRON_UTC_HOUR=8

# Scheduled drift checks (uses saved DB profiles; requires SMTP for email alerts)
# DRIFT_CHECK_CRON=true

# Scheduled custom reports (admin-defined report definitions; requires SMTP for delivery)
# SCHEDULED_REPORT_CRON=true

# Redis (optional — distributed rate limits across API instances when set)
# REDIS_URL=redis://localhost:6379
# REDIS_RATE_LIMIT_PREFIX=dbforge:rl:

# Per-route rate limits (enforced in production only; dev skips route limiters)
# RATE_LIMIT_EXPENSIVE_DB_MAX=20          # drift + introspect per user / 15 min
# RATE_LIMIT_LOGIN_MAX=10                   # login attempts per IP
# RATE_LIMIT_LOGIN_WINDOW_MS=60000          # login window (default 1 min)
# RATE_LIMIT_FORGOT_PASSWORD_MAX=5          # forgot-password per IP
# RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MS=3600000
# RATE_LIMIT_AI_MAX=30                      # AI routes per user / 15 min
# RATE_LIMIT_EXPORT_MAX=60                  # project exports per user / 15 min
# RATE_LIMIT_ADMIN_BACKUP_MAX=10            # admin backup per user
# RATE_LIMIT_ADMIN_BACKUP_WINDOW_MS=3600000

# Optional error monitoring (structured JSON logged to stdout; connect log drain)
# SENTRY_DSN=

# OAuth / SSO (optional — shows provider buttons on login when credentials are set)
# API_PUBLIC_URL=http://localhost:4000
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CALLBACK_URL=http://localhost:4000/api/auth/oauth/google/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:4000/api/auth/oauth/github/callback
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT=common
# MICROSOFT_OAUTH_CALLBACK_URL=http://localhost:4000/api/auth/oauth/microsoft/callback

# Comment attachment storage (optional — default: team-erd-api/uploads/comment-attachments)
# COMMENT_ATTACHMENTS_DIR=/var/lib/dbforge/comment-attachments

# OpenAI (optional — AI schema generator falls back to built-in patterns)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
