NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://root:root@localhost:3306/dbforge"
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# Registration (defaults: allowed in dev, blocked in production)
# ALLOW_PUBLIC_REGISTRATION=true

# Encrypt saved database connection profiles (required in production)
# DB_PROFILE_ENCRYPTION_KEY=generate-a-long-random-secret

# SMTP (optional — without these, email logs to API console in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=DBForge <noreply@yourcompany.com>

# Weekly team digest cron (UTC Monday 08:00 by default; requires SMTP)
# WEEKLY_DIGEST_CRON=true
# WEEKLY_DIGEST_CRON_UTC_DAY=1
# WEEKLY_DIGEST_CRON_UTC_HOUR=8

# Scheduled drift checks (uses saved DB profiles; requires SMTP for email alerts)
# DRIFT_CHECK_CRON=true

# Rate limit drift/introspect per user (per 15 min window; production default 20)
# RATE_LIMIT_EXPENSIVE_DB_MAX=20

# Optional error monitoring (structured JSON logged to stdout; connect log drain)
# SENTRY_DSN=

# OpenAI (optional — AI schema generator falls back to built-in patterns)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
