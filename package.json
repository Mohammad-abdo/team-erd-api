{
  "name": "dbforge-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --testPathIgnorePatterns=\\.integration\\.test\\.js",
    "test:integration": "cross-env INTEGRATION_TESTS=1 NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=\\.integration\\.test\\.js",
    "test:all": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch --testPathIgnorePatterns=\\.integration\\.test\\.js",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --testPathIgnorePatterns=\\.integration\\.test\\.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "lint": "eslint src"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "nodemailer": "^6.10.0",
    "pg": "^8.21.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2"
  }
}
