}

model ProjectTask {
  id          String       @id @default(cuid())
  projectId   String       @map("project_id")
  title       String       @db.VarChar(300)
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  progress    Int          @default(0)
  dueDate     DateTime?    @map("due_date")
  sortOrder   Int          @default(0) @map("sort_order")
  createdById String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  completedAt DateTime?    @map("completed_at")

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignees    TaskAssignee[]
  progressLogs TaskProgressLog[]
  focusItems   TodayFocusItem[]

  @@index([projectId, status])
  @@index([projectId, dueDate])
  @@map("project_tasks")
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskProgressLog {
  id       String   @id @default(cuid())
  taskId   String   @map("task_id")
  userId   String   @map("user_id")
  progress Int
  note     String?  @db.Text
  logDate  DateTime @map("log_date") @db.Date
  loggedAt DateTime @default(now()) @map("logged_at")

  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, logDate])
  @@map("task_progress_logs")
}

model DailyTask {
  id          String          @id @default(cuid())
  teamId      String          @map("team_id")
  title       String          @db.VarChar(300)
  description String?         @db.Text
  status      TaskStatus      @default(TODO)
  priority    TaskPriority    @default(MEDIUM)
  taskDate    DateTime        @map("task_date") @db.Date
  assigneeId  String          @map("assignee_id")
  createdById String          @map("created_by")
  source      DailyTaskSource @default(PERSONAL)
  completedAt DateTime?       @map("completed_at")
