// DBForge — application database schema
// https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProjectVisibility {
  PRIVATE
  PUBLIC
}

enum ProjectMemberRole {
  LEADER
  EDITOR
  VIEWER
  COMMENTER
}

enum ErdRelationType {
  ONE_TO_ONE
  ONE_TO_MANY
  MANY_TO_MANY
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum ApiRouteStatus {
  DRAFT
  STABLE
  DEPRECATED
}

enum ApiParameterLocation {
  PATH
  QUERY
  BODY
  HEADER
}

enum CommentableType {
  ERD_TABLE
  ERD_RELATION
  API_ROUTE
}

enum PermissionResource {
  ERD
  API
  COMMENTS
  EXPORTS
  TASKS
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
}

enum PlatformRole {
  SUPER_ADMIN
  MEMBER
  CLIENT
}

enum TeamRole {
  TEAM_LEAD
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum DailyTaskSource {
  PERSONAL
  ASSIGNED
}

model User {
  id           String       @id @default(cuid())
  name         String       @db.VarChar(200)
  email        String       @unique @db.VarChar(255)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  avatar       String?
  platformRole PlatformRole @default(MEMBER) @map("platform_role")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  projectsLed    Project[]           @relation("ProjectLeader")
  projectMembers       ProjectMember[]
  projectMembersInvited ProjectMember[] @relation("MemberInvitedBy")

  erdTablesCreated    ErdTable[]    @relation("ErdTableCreatedBy")
  erdRelationsCreated ErdRelation[] @relation("ErdRelationCreatedBy")
  apiRoutesCreated    ApiRoute[]    @relation("ApiRouteCreatedBy")

  comments         Comment[]
  activityLogs     ActivityLog[]
  notifications    Notification[]
  permissions      ProjectPermission[] @relation("PermissionUser")
  permissionsGranted ProjectPermission[] @relation("PermissionGrantedBy")
  apiTestSettings  ApiTestSetting[]
  teamMemberships  TeamMember[]
  teamsCreated     Team[]           @relation("TeamCreatedBy")
  adminAudits      AdminAuditLog[]  @relation("AdminAuditActor")
  templatesCreated ProjectTemplate[] @relation("TemplateCreatedBy")
  erdSnapshotsCreated ErdSnapshot[]   @relation("ErdSnapshotCreatedBy")
  webhooksCreated     ProjectWebhook[] @relation("WebhookCreatedBy")
  tasksCreated        ProjectTask[]    @relation("TaskCreatedBy")
  taskAssignments     TaskAssignee[]
  taskProgressLogs    TaskProgressLog[]
  dailyTasksAssigned  DailyTask[]      @relation("DailyTaskAssignee")
  dailyTasksCreated   DailyTask[]      @relation("DailyTaskCreatedBy")
  ratingsReceived     MemberRating[]   @relation("RatingsReceived")
  ratingsGiven        MemberRating[]   @relation("RatingsGiven")
  dailyReports        DailyReport[]
  clientProjectAccess ClientProjectAccess[]
  driftReportsChecked ProjectDriftReport[] @relation("DriftReportCheckedBy")
  dbProfilesCreated   ProjectDbProfile[]   @relation("DbProfileCreatedBy")
  driftSchedulesCreated ProjectDriftSchedule[] @relation("DriftScheduleCreatedBy")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique @db.VarChar(128)
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Project {
  id          String            @id @default(cuid())
  name        String            @db.VarChar(200)
  slug        String            @unique @db.VarChar(200)
  description String?           @db.Text
  leaderId       String            @map("leader_id")
  visibility     ProjectVisibility @default(PRIVATE)
  healthStage    String?           @map("health_stage") @db.VarChar(30)
  lastActivityAt DateTime?         @map("last_activity_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  leader User @relation("ProjectLeader", fields: [leaderId], references: [id], onDelete: Restrict)

  members      ProjectMember[]
  invitations  ProjectInvitation[]
  erdTables    ErdTable[]
  erdRelations ErdRelation[]
  apiGroups    ApiGroup[]
  comments     Comment[]
  activityLogs    ActivityLog[]
  permissions     ProjectPermission[]
  apiTestSettings ApiTestSetting[]
  teamProjects    TeamProject[]
  erdSnapshots    ErdSnapshot[]
  webhooks        ProjectWebhook[]
  tasks           ProjectTask[]
  memberRatings   MemberRating[]
  dailyReports    DailyReport[]
  clientAccess    ClientProjectAccess[]
  driftReports    ProjectDriftReport[]
  dbProfiles      ProjectDbProfile[]
  driftSchedule   ProjectDriftSchedule?

  @@index([leaderId])
  @@index([healthStage])
  @@map("projects")
}

model ProjectDriftReport {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  dialect       String   @db.VarChar(20)
  databaseLabel String   @map("database_label") @db.VarChar(200)
  inSync        Boolean  @map("in_sync")
  issueCount    Int      @map("issue_count")
  reportJson    Json     @map("report_json")
  checkedById   String   @map("checked_by")
  createdAt     DateTime @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  checkedBy User    @relation("DriftReportCheckedBy", fields: [checkedById], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@map("project_drift_reports")
}

model ProjectDbProfile {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  name         String   @db.VarChar(120)
  environment  String   @default("development") @db.VarChar(30)
  dialect      String   @db.VarChar(20)
  host         String   @db.VarChar(255)
  port         Int      @default(3306)
  user         String   @db.VarChar(120)
  passwordEnc  String   @map("password_enc") @db.Text
  database     String   @db.VarChar(200)
  schemaName   String?  @map("schema_name") @db.VarChar(128)
  createdById  String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project       Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy     User                  @relation("DbProfileCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  driftSchedule ProjectDriftSchedule?

  @@unique([projectId, name, environment])
  @@index([projectId])
  @@index([projectId, environment])
  @@map("project_db_profiles")
}

model ProjectDriftSchedule {
  id             String    @id @default(cuid())
  projectId      String    @unique @map("project_id")
  profileId      String    @unique @map("profile_id")
  enabled        Boolean   @default(true)
  utcDay         Int       @default(1) @map("utc_day")
  utcHour        Int       @default(6) @map("utc_hour")
  lastRunAt      DateTime? @map("last_run_at")
  lastRunStatus  String?   @map("last_run_status") @db.VarChar(30)
  lastIssueCount Int?      @map("last_issue_count")
  createdById    String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profile   ProjectDbProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdBy User             @relation("DriftScheduleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([profileId])
  @@map("project_drift_schedules")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(120)
  slug        String   @unique @db.VarChar(120)
  description String?  @db.Text
  color       String   @default("#0d9488") @db.VarChar(32)
  icon        String?  @db.VarChar(32)
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy  User         @relation("TeamCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  members    TeamMember[]
  projects      TeamProject[]
  dailyTasks    DailyTask[]
  memberRatings MemberRating[]
  dailyReports  DailyReport[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_members")
}

model TeamProject {
  id         String   @id @default(cuid())
  teamId     String   @map("team_id")
  projectId  String   @map("project_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([teamId, projectId])
  @@index([projectId])
  @@map("team_projects")
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String   @db.VarChar(80)
  entityType String   @map("entity_type") @db.VarChar(80)
  entityId   String?  @map("entity_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation("AdminAuditActor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("admin_audit_logs")
}

model ProjectTemplate {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?  @db.Text
  erdJson     Json?    @map("erd_json")
  apiJson     Json?    @map("api_json")
  isPublic    Boolean  @default(true) @map("is_public")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy User @relation("TemplateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@map("project_templates")
}

model ProjectMember {
  id         String            @id @default(cuid())
  projectId  String            @map("project_id")
  userId     String            @map("user_id")
  role       ProjectMemberRole
  invitedById String?          @map("invited_by")
  joinedAt   DateTime          @default(now()) @map("joined_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("MemberInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ClientProjectAccess {
  id           String  @id @default(cuid())
  projectId    String  @map("project_id")
  userId       String  @map("user_id")
  viewOverview Boolean @default(true) @map("view_overview")
  viewErd      Boolean @default(true) @map("view_erd")
  viewApi      Boolean @default(false) @map("view_api")
  viewReport   Boolean @default(true) @map("view_report")
  viewTasks    Boolean @default(true) @map("view_tasks")
  viewComments Boolean @default(false) @map("view_comments")
  viewActivity Boolean @default(false) @map("view_activity")
  viewHealth   Boolean @default(false) @map("view_health")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("client_project_access")
}

model ProjectInvitation {
  id         String    @id @default(cuid())
  projectId  String    @map("project_id")
  email      String
  token      String    @unique
  role       ProjectMemberRole
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_invitations")
}

model ProjectWebhook {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  url             String    @db.VarChar(500)
  secret          String?   @db.VarChar(128)
  events          Json
  isActive        Boolean   @default(true) @map("is_active")
  createdById     String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  lastStatus      Int?      @map("last_status")
  lastError       String?   @map("last_error") @db.VarChar(500)
  lastTriggeredAt DateTime? @map("last_triggered_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("WebhookCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@map("project_webhooks")
}

model ErdSnapshot {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  label          String   @db.VarChar(200)
  snapshotJson   Json     @map("snapshot_json")
  tableCount     Int      @default(0) @map("table_count")
  relationCount  Int      @default(0) @map("relation_count")
  createdById    String   @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ErdSnapshotCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId, createdAt])
  @@map("erd_snapshots")
}

model ErdTable {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  label       String?
  color       String?
  groupName   String?  @map("group_name")
  x           Float    @default(0)
  y           Float    @default(0)
  description String?  @db.Text
  createdById String   @map("created_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ErdTableCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  columns           ErdColumn[]
  indexes           ErdTableIndex[]
  checkConstraints  ErdCheckConstraint[]
  relationsFrom     ErdRelation[] @relation("ErdRelationFromTable")
  relationsTo       ErdRelation[] @relation("ErdRelationToTable")
  apiRouteLinks     ApiRouteErdLink[]

  @@index([projectId])
  @@map("erd_tables")
}

model ErdTableIndex {
  id          String  @id @default(cuid())
  tableId     String  @map("table_id")
  name        String?
  columnNames Json    @map("column_names")
  isUnique    Boolean @default(false) @map("is_unique")
  sortOrder   Int     @default(0) @map("sort_order")

  table ErdTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@map("erd_table_indexes")
}

model ErdCheckConstraint {
  id         String  @id @default(cuid())
  tableId    String  @map("table_id")
  name       String?
  expression String  @db.Text
  sortOrder  Int     @default(0) @map("sort_order")

  table ErdTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@map("erd_check_constraints")
}

model ErdColumn {
  id           String   @id @default(cuid())
  tableId      String   @map("table_id")
  name         String
  dataType     String   @map("data_type")
  isPk         Boolean  @default(false) @map("is_pk")
  isFk         Boolean  @default(false) @map("is_fk")
  isNullable   Boolean  @default(true) @map("is_nullable")
  isUnique     Boolean  @default(false) @map("is_unique")
  defaultValue String?  @map("default_value")
  description  String?  @db.Text
  sortOrder    Int      @default(0) @map("sort_order")

  table ErdTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  relationsFrom ErdRelation[] @relation("ErdRelationFromColumn")
  relationsTo   ErdRelation[] @relation("ErdRelationToColumn")

  @@index([tableId])
  @@map("erd_columns")
}

model ErdRelation {
  id           String           @id @default(cuid())
  projectId    String           @map("project_id")
  fromTableId  String           @map("from_table_id")
  toTableId    String           @map("to_table_id")
  relationType ErdRelationType  @map("relation_type")
  fromColumnId String?          @map("from_column_id")
  toColumnId   String?          @map("to_column_id")
  label        String?
  createdById  String           @map("created_by")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromTable ErdTable  @relation("ErdRelationFromTable", fields: [fromTableId], references: [id], onDelete: Cascade)
  toTable   ErdTable  @relation("ErdRelationToTable", fields: [toTableId], references: [id], onDelete: Cascade)
  fromColumn ErdColumn? @relation("ErdRelationFromColumn", fields: [fromColumnId], references: [id], onDelete: SetNull)
  toColumn   ErdColumn? @relation("ErdRelationToColumn", fields: [toColumnId], references: [id], onDelete: SetNull)
  createdBy User      @relation("ErdRelationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([fromTableId])
  @@index([toTableId])
  @@map("erd_relations")
}

model ApiGroup {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  name        String
  prefix      String   @default("")
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")

  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  routes  ApiRoute[]

  @@index([projectId])
  @@map("api_groups")
}

model ApiRoute {
  id            String          @id @default(cuid())
  groupId       String          @map("group_id")
  method        HttpMethod
  path          String
  summary       String?
  description   String?         @db.Text
  authRequired  Boolean         @default(false) @map("auth_required")
  roleRequired  String?         @map("role_required")
  status        ApiRouteStatus  @default(DRAFT)
  createdById   String          @map("created_by")

  group     ApiGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User     @relation("ApiRouteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  parameters ApiParameter[]
  responses  ApiRouteResponse[]
  erdLinks   ApiRouteErdLink[]

  @@index([groupId])
  @@map("api_routes")
}

model ApiRouteErdLink {
  id         String   @id @default(cuid())
  routeId    String   @map("route_id")
  erdTableId String   @map("erd_table_id")
  createdAt  DateTime @default(now()) @map("created_at")

  route    ApiRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  erdTable ErdTable @relation(fields: [erdTableId], references: [id], onDelete: Cascade)

  @@unique([routeId, erdTableId])
  @@index([routeId])
  @@index([erdTableId])
  @@map("api_route_erd_links")
}

model ApiParameter {
  id          String               @id @default(cuid())
  routeId     String               @map("route_id")
  location    ApiParameterLocation
  name        String
  dataType    String               @map("data_type")
  isRequired  Boolean              @default(false) @map("is_required")
  description String?              @db.Text
  example     String?              @db.Text

  route ApiRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@map("api_parameters")
}

model ApiRouteResponse {
  id          String @id @default(cuid())
  routeId     String @map("route_id")
  statusCode  Int    @map("status_code")
  description String? @db.Text
  exampleJson String? @map("example_json") @db.LongText

  route ApiRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@map("api_responses")
}

model Comment {
  id               String          @id @default(cuid())
  projectId        String          @map("project_id")
  commentableType  CommentableType @map("commentable_type")
  commentableId    String          @map("commentable_id")
  userId           String          @map("user_id")
  body             String          @db.Text
  parentId         String?         @map("parent_id")
  resolvedAt       DateTime?       @map("resolved_at")
  createdAt        DateTime        @default(now()) @map("created_at")

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Comment?            @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]           @relation("CommentThread")
  attachments CommentAttachment[]

  @@index([projectId])
  @@index([commentableType, commentableId])
  @@map("comments")
}

model CommentAttachment {
  id           String   @id @default(cuid())
  commentId    String   @map("comment_id")
  fileName     String   @map("file_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(120)
  sizeBytes    Int      @map("size_bytes")
  storagePath  String   @map("storage_path") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_attachments")
}

model ActivityLog {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@map("activity_logs")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String?   @db.Text
  data      Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model ApiTestSetting {
  id                String  @id @default(cuid())
  projectId         String  @map("project_id")
  userId            String  @map("user_id")
  baseUrl           String  @default("http://localhost:3000") @map("base_url") @db.VarChar(500)
  authToken         String? @map("auth_token") @db.Text
  activeEnvironment String  @default("dev") @map("active_environment") @db.VarChar(50)
  environments      Json?
  headers           Json?
  body              String? @db.LongText

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("api_test_settings")
}

model ProjectPermission {
  id         String             @id @default(cuid())
  projectId  String             @map("project_id")
  userId     String             @map("user_id")
  resource   PermissionResource
  action     PermissionAction
  grantedById String?           @map("granted_by")
  grantedAt  DateTime           @default(now()) @map("granted_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("PermissionUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?   @relation("PermissionGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([projectId, userId, resource, action])
  @@index([projectId])
  @@map("project_permissions")
}

model ProjectTask {
  id          String       @id @default(cuid())
  projectId   String       @map("project_id")
  title       String       @db.VarChar(300)
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  progress    Int          @default(0)
  dueDate     DateTime?    @map("due_date")
  sortOrder   Int          @default(0) @map("sort_order")
  createdById String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  completedAt DateTime?    @map("completed_at")

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignees    TaskAssignee[]
  progressLogs TaskProgressLog[]

  @@index([projectId, status])
  @@index([projectId, dueDate])
  @@map("project_tasks")
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskProgressLog {
  id       String   @id @default(cuid())
  taskId   String   @map("task_id")
  userId   String   @map("user_id")
  progress Int
  note     String?  @db.Text
  logDate  DateTime @map("log_date") @db.Date
  loggedAt DateTime @default(now()) @map("logged_at")

  task ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, logDate])
  @@map("task_progress_logs")
}

model DailyTask {
  id          String          @id @default(cuid())
  teamId      String          @map("team_id")
  title       String          @db.VarChar(300)
  description String?         @db.Text
  status      TaskStatus      @default(TODO)
  priority    TaskPriority    @default(MEDIUM)
  taskDate    DateTime        @map("task_date") @db.Date
  assigneeId  String          @map("assignee_id")
  createdById String          @map("created_by")
  source      DailyTaskSource @default(PERSONAL)
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assignee  User @relation("DailyTaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdBy User @relation("DailyTaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([teamId, taskDate])
  @@index([assigneeId, taskDate])
  @@map("daily_tasks")
}

model MemberRating {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  reviewerId String   @map("reviewer_id")
  teamId     String?  @map("team_id")
  projectId  String?  @map("project_id")
  score      Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation("RatingsReceived", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User     @relation("RatingsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  team     Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([teamId])
  @@map("member_ratings")
}

enum DailyReportScope {
  GENERAL
  PROJECT
  TASKS
}

model DailyReport {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  teamId      String?          @map("team_id")
  projectId   String?          @map("project_id")
  scope       DailyReportScope @default(GENERAL)
  reportDate  DateTime         @map("report_date") @db.Date
  summary     String           @db.Text
  tasksDone   String?          @map("tasks_done") @db.Text
  blockers    String?          @db.Text
  nextPlan    String?          @map("next_plan") @db.Text
  hoursWorked Float?           @map("hours_worked")
  mood        Int?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team    Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, reportDate])
  @@index([teamId, reportDate])
  @@index([projectId, reportDate])
  @@map("daily_reports")
}
